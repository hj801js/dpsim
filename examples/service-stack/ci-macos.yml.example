      #   env:
      #     AMQP_ADDR: amqp://guest:guest@localhost:5672/%2f
      #     REDIS_URL: redis://localhost:6379/
      #     FILE_SERVICE_URL: http://127.0.0.1:18080
      #     PYTHONPATH: ${GITHUB_WORKSPACE}/build:${GITHUB_WORKSPACE}/python/src
      #   run: |
      #     python3 examples/service-stack/file_service_stub.py &
      #     python3 examples/service-stack/worker.py &
      #     dpsim-api/target/release/dpsim-api &
      #     sleep 5
      #     bash examples/service-stack/smoke.sh
